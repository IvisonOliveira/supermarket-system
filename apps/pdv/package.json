{
  "name": "@supermarket/pdv",
  "version": "1.0.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "dist": "electron-builder --dir",
    "pack": "electron-builder",
    "typecheck": "yarn typecheck:main && yarn typecheck:renderer",
    "typecheck:main": "tsc --noEmit -p tsconfig.main.json",
    "typecheck:renderer": "tsc --noEmit -p tsconfig.json",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3 || true",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0",
    "test": "vitest run"
  },
  "dependencies": {
    "better-sqlite3": "^9.6.0",
    "electron-store": "^8.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.0",
    "serialport": "^12.0.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.4"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/better-sqlite3": "^7.6.10",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.10",
    "vite-plugin-electron": "^0.28.5",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^1.5.0"
  },
  "build": {
    "appId": "com.supermarket.pdv",
    "productName": "Supermarket PDV",
    "copyright": "Copyright © 2024",
    "directories": {
      "output": "release",
      "buildResources": "public"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/serialport/**",
      "**/node_modules/@serialport/**",
      "**/node_modules/bindings/**",
      "**/node_modules/node-gyp-build/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico"
    },
    "extraResources": [
      {
        "from": "public/fonts",
        "to": "fonts",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
