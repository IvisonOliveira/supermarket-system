{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "outDir": "./dist",
    "paths": {
      "@supermarket/shared": ["../../packages/shared/src"]
    },
    "incremental": true,
    "emitDecoratorMetadata": true,
