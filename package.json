{
  "name": "supermarket-system",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm run dev -w @supermarket/backend",
    "dev:admin": "npm run dev -w @supermarket/admin",
    "dev:pdv": "npm run dev -w @supermarket/pdv",
    "build:backend": "npm run build -w @supermarket/backend",
    "build:admin": "npm run build -w @supermarket/admin",
    "build:pdv": "npm run build -w @supermarket/pdv",
    "lint": "npm run lint --workspaces",
    "lint:check": "npm run lint --workspaces",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\" --ignore-path .prettierignore",
    "test": "npm run test --workspaces",
    "test:ci": "npm run test:ci -w @supermarket/backend && npm run test:ci -w @supermarket/admin"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.34.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "yarn": ">=1.22.0"
  }
}
